# Copy this file as .env.production and replace every CHANGE_ME value.
# Prefer long hexadecimal values so DATABASE_URL does not require URL encoding.

# PostgreSQL container credentials
POSTGRES_USER=wedding
POSTGRES_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
POSTGRES_DB=wedding_db

# Must use the same user, password and database values declared above.
# "postgres" is the Docker Compose service hostname; do not replace it with localhost.
DATABASE_URL=postgresql://wedding:CHANGE_ME_DATABASE_PASSWORD@postgres:5432/wedding_db?schema=public
DIRECT_URL=postgresql://wedding:CHANGE_ME_DATABASE_PASSWORD@postgres:5432/wedding_db?schema=public

# Secret entered on /admin. Use a different value from the database password.
ADMIN_API_KEY=CHANGE_ME_ADMIN_API_KEY

# Personal Google account OAuth2 credentials for private Drive uploads.
GOOGLE_CLIENT_ID=CHANGE_ME_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=CHANGE_ME_GOOGLE_CLIENT_SECRET
GOOGLE_REFRESH_TOKEN=CHANGE_ME_GOOGLE_REFRESH_TOKEN
GOOGLE_DRIVE_FOLDER_ID=CHANGE_ME_GOOGLE_DRIVE_FOLDER_ID

# Memory corner upload gate.
# open: allow uploads immediately, closed: block uploads, scheduled: open at MEMORY_UPLOAD_OPEN_AT.
MEMORY_UPLOAD_MODE=scheduled
MEMORY_UPLOAD_OPEN_AT=2026-09-05T20:00:00+03:00

# Public port exposed by the production frontend container.
APP_PORT=80
