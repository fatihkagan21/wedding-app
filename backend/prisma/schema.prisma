// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider = "postgresql"
}

generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  moduleFormat        = "esm"
  importFileExtension = "js"
}

model Event {
  id            String   @id @default(uuid())

  title         String
  brideName     String
  groomName     String
  description   String?

  venueName     String
  venueAddress  String

  eventDate     DateTime

  heroImageUrl  String?
  musicUrl      String?
  googleMapsUrl      String?
  googleMapsEmbedUrl String?
  
  createdAt     DateTime @default(now())

  rsvps         Rsvp[]
  guestListEntries GuestListEntry[]
}

model Rsvp {
  id              String   @id @default(uuid())

  eventId         String
  event           Event    @relation(fields: [eventId], references: [id])

  contactFullName String
  attending       Boolean

  attendeeCount   Int?
  attendees       Json?

  notes           String?

  createdAt       DateTime @default(now())
  guestListEntry  GuestListEntry?
}

model GuestListEntry {
  id                  String   @id @default(uuid())

  eventId             String
  event               Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  rsvpId              String?  @unique
  rsvp                Rsvp?    @relation(fields: [rsvpId], references: [id], onDelete: SetNull)

  displayName         String
  side                String   @default("shared")
  plannedGuestCount   Int      @default(1)
  phone               String?
  invitationStatus    String   @default("not-sent")
  forecastStatus      String   @default("unknown")
  notes               String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([eventId])
}
