// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider = "postgresql"
}

generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  moduleFormat        = "esm"
  importFileExtension = "js"
}

model Event {
  id            String   @id @default(uuid())

  title         String
  brideName     String
  groomName     String
  description   String?

  venueName     String
  venueAddress  String

  eventDate     DateTime

  heroImageUrl  String?
  musicUrl      String?
  googleMapsUrl      String?
  googleMapsEmbedUrl String?
  
  createdAt     DateTime @default(now())

  rsvps         Rsvp[]
}

model Rsvp {
  id              String   @id @default(uuid())

  eventId         String
  event           Event    @relation(fields: [eventId], references: [id])

  contactFullName String
  attending       Boolean

  attendeeCount   Int?
  attendees       Json?

  notes           String?

  createdAt       DateTime @default(now())
}
